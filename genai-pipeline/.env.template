# storyboard-ai env config — copy to .env and adjust if needed.
# Pre-filled from /Users/jfogarty/prj/archive/chain-mountain/cm-vertex-demo
# (your existing Vertex AI demo project).

# ---------- Vertex AI via corporate GCP (preferred, matches cm-vertex-demo) ----------
GOOGLE_GENAI_USE_VERTEXAI=True
GOOGLE_CLOUD_PROJECT=cm-iq-demo
GOOGLE_CLOUD_LOCATION=us-east1

# Path to the existing service-account key file (same one cm-vertex-demo uses).
# Confirm this file exists. If you've moved it, update the path.
GOOGLE_APPLICATION_CREDENTIALS=/Users/jfogarty/prj/chain-mountain/cm-iq/cm-iq-app/secrets/cm-iq-sa-key.json

# ---------- Optional fallback: Gen AI API key (only used if Vertex flag above is unset) ----------
# Leave commented out unless you want to fall back to API-key mode for testing.
# GEMINI_API_KEY=

# ---------- SAM 3 endpoint ----------
# Default = upstream public Cloud Run endpoint (works out of the box).
# For corporate compliance, deploy your own SAM 3 service in cm-iq-demo and override here.
# SAM_API_URL=https://your-sam-endpoint-in-cm-iq-demo.run.app/predict
